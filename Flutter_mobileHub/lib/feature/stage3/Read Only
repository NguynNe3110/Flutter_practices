Bước 1: Cài đặt Package
    flutter pub add go_router
----

Bước 2: Định nghĩa các Route cơ bản (Tư duy như viết nav_graph.xml hoặc NavHost)
Tạo file core/router/app_router.dart:
import 'package:flutter/material.dart';
import 'package:go_router/go_router.dart';

    // 1. Định nghĩa tên route (Tránh dùng string cứng, giống常量 trong Kotlin)
    class AppRoutes {
      static const String login = '/login';
      static const String home = '/home';
      static const String detail = '/detail';
    }

    // 2. Cấu hình GoRouter
    final GoRouter appRouter = GoRouter(
      initialLocation: AppRoutes.login,
      routes: [
        // Route Login
        GoRoute(
          path: AppRoutes.login,
          builder: (context, state) => const LoginScreen(),
        ),

        // Route Home
        GoRoute(
          path: AppRoutes.home,
          builder: (context, state) => const HomeScreen(),
          // Route con (Nested Route) - Giống sub-graph trong Android
          routes: [
            GoRoute(
              path: 'detail/:id', // :id là path parameter (giống SafeArgs)
              builder: (context, state) {
                final id = state.pathParameters['id']!;
                // Lấy object phức tạp truyền qua extra (giống Parcelable/Serializable)
                final user = state.extra as User?;
                return DetailScreen(id: id, user: user);
              },
            ),
          ],
        ),
      ],
LOGIC CHO SAVE TOKEN
      // 3. Redirect Logic (Rất quan trọng cho Auth Flow)
      // Tương tự việc check token trong Interceptor hoặc NavigationUI
      redirect: (context, state) {
        final isLoggedIn = AuthService.instance.isLoggedIn; // Giả sử có class check login
        final isOnLoginPage = state.matchedLocation == AppRoutes.login;

        if (!isLoggedIn && !isOnLoginPage) return AppRoutes.login;
        if (isLoggedIn && isOnLoginPage) return AppRoutes.home;

        return null; // Không redirect
      },
    );
